{% extends "core/component_details_private_base.html.j2" %}
{% load static %}
{% load django_vite %}
{% block content_after_header %}
    {# Artifacts & security — the SBOM versions list leads the page, with vulnerabilities shown per version (design review p9: "one wholistic view at the top"). #}
    <div id="sboms-table-container"
         hx-get="{% url 'sboms:sboms_table' component.id %}"
         hx-trigger="load, refreshSbomsTable from:body"
         hx-swap="innerHTML">
        <div class="text-center py-8">
            <div class="animate-spin w-8 h-8 border-4 border-primary border-t-transparent rounded-full mx-auto"
                 role="status">
                <span class="sr-only">Loading...</span>
            </div>
            <p class="mt-3 text-text-muted">Loading SBOMs...</p>
        </div>
    </div>
    {# VEX documents uploaded for this component. refreshSbomsTable also refreshes it, so an upload reflects immediately. #}
    <div id="vex-documents-container"
         class="mt-4"
         hx-get="{% url 'sboms:component_vex_documents' component.id %}"
         hx-trigger="load, refreshVexDocuments from:body, refreshSbomsTable from:body"
         hx-swap="innerHTML">
        <div class="tw-card">
            <div class="tw-card-body text-text-muted text-sm">Loading VEX documents…</div>
        </div>
    </div>
    {# Post-Quantum posture — lazy-loaded; collapses when the latest artifact has no crypto assets #}
    <div hx-get="{% url 'sboms:component_crypto_posture' component_id=component.id %}"
         hx-trigger="load"
         hx-swap="outerHTML"></div>
{% endblock %}
{% block upload_section %}
    {% if component.has_crud_permissions %}
        <div>{% include "sboms/components/ci_cd_info.html.j2" %}</div>
        <div id="upload-section">{% include 'sboms/components/sbom_upload.html.j2' with component_id=component.id %}</div>
        <div id="trusted-publishers"
             hx-get="{% url 'oidc:trusted_publishers' component_id=component.id %}"
             hx-trigger="load"
             hx-swap="outerHTML">
            {# placeholder, replaced by the rendered section partial on load #}
            <div class="tw-card tw-card-bordered">
                <div class="tw-card-body text-text-muted text-sm">Loading trusted publishers…</div>
            </div>
        </div>
    {% endif %}
{% endblock %}
{% block table_section %}
    {# Component metadata — collapsed, below the artifacts (design review p8: "far too much on this page"). Editing opens it from the header ⋮ menu. #}
    <div id="component-metadata">{% include "core/components/component_meta_info.html.j2" %}</div>
{% endblock %}
{% block scripts_additional %}
    {% vite_asset 'sbomify/apps/sboms/js/main.ts' %}
{% endblock %}
