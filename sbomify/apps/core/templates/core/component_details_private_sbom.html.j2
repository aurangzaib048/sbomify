{% extends "core/component_details_private_base.html.j2" %}
{% load static %}
{% load django_vite %}
{% block content_after_header %}
    {# Artifacts & security — the SBOM versions list leads the page, with vulnerabilities shown per version (design review p9: "one wholistic view at the top"). #}
    <div id="sboms-table-container"
         hx-get="{% url 'sboms:sboms_table' component.id %}"
         hx-trigger="load, refreshSbomsTable from:body, refreshVexDocuments from:body"
         hx-swap="innerHTML">
        <div class="text-center py-8">
            <div class="animate-spin w-8 h-8 border-4 border-primary border-t-transparent rounded-full mx-auto"
                 role="status">
                <span class="sr-only">Loading...</span>
            </div>
            <p class="mt-3 text-text-muted">Loading SBOMs...</p>
        </div>
    </div>
    {# Vulnerabilities drill-down for the latest SBOM — hidden when the latest scan is clean #}
    {% include "core/components/component_vulnerabilities.html.j2" %}
    {# Post-Quantum posture — lazy-loaded; collapses when the latest artifact has no crypto assets #}
    <div hx-get="{% url 'sboms:component_crypto_posture' component_id=component.id %}"
         hx-trigger="load"
         hx-swap="outerHTML"></div>
{% endblock %}
{% block upload_section %}
    {% if component.has_crud_permissions %}
        {# Modals opened from the header ⋮ menu — nothing here renders in the page flow. #}
        {% include "sboms/components/ci_cd_info.html.j2" %}
        <div id="upload-section">{% include 'sboms/components/sbom_upload.html.j2' with component_id=component.id %}</div>
        {% include "core/components/trusted_publishers_modal.html.j2" %}
    {% endif %}
{% endblock %}
{% block table_section %}
    {# Component metadata modal — opened from the header ⋮ menu; available to every member (editing is gated inside). #}
    {% include "core/components/component_meta_info.html.j2" %}
{% endblock %}
{% block scripts_additional %}
    {% vite_asset 'sbomify/apps/sboms/js/main.ts' %}
{% endblock %}
