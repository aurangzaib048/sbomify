{% extends "core/dashboard_base.htmx.j2" %}
{% load static %}
{% load django_vite %}
{% load humanize %}
{% load utils %}
{% load public_url_tags %}
{% block title %}sbomify Product: {{ product.name }}{% endblock %}
{% block content %}
    <div class="space-y-6">
        {# Page Header - matches component page pattern #}
        <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4">
            <div class="flex items-start gap-4">
                <div class="tw-avatar tw-avatar-lg">
                    <i class="fas fa-cube"></i>
                </div>
                <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-3 flex-wrap">
                        <h1 class="text-2xl font-bold text-text">
                            {% if product.has_crud_permissions %}
                                {% include 'core/components/editable_single_field.html.j2' with item_type='product' item_id=product.id item_value=product.name %}
                            {% else %}
                                {{ product.name }}
                            {% endif %}
                        </h1>
                        <div class="flex items-center gap-2 text-sm text-text-muted">
                            {% include 'core/components/copyable_value.html.j2' with value=product.id title="Product ID: "|add:product.id|add:" (click to copy)" %}
                            {% if product_tei %}
                                {% include 'core/components/copyable_value.html.j2' with value=product_tei title="TEI: "|add:product_tei|add:" (click to copy)" %}
                            {% endif %}
                        </div>
                    </div>
                    {# Description Section #}
                    {% if product.has_crud_permissions %}
                        <div x-data="{ editing: false }" class="mt-1">
                            <template x-if="!editing">
                                <div class="flex items-center gap-2 cursor-pointer group"
                                     role="button"
                                     tabindex="0"
                                     @click="editing = true"
                                     @keydown.enter.prevent="editing = true">
                                    {% if product.description %}
                                        <p class="text-text-muted text-sm m-0">{{ product.description }}</p>
                                    {% else %}
                                        <p class="text-text-muted text-sm italic m-0">Add a description...</p>
                                    {% endif %}
                                    <i class="fas fa-pencil-alt text-text-muted text-xs opacity-0 group-hover:opacity-100 transition-opacity"
                                       aria-hidden="true"></i>
                                </div>
                            </template>
                            <template x-if="editing">
                                <form method="post"
                                      action="{% url 'core:product_details' product.id %}"
                                      class="max-w-xl mt-2">
                                    {% csrf_token %}
                                    <input type="hidden" name="action" value="update_description">
                                    <textarea name="description"
                                              class="tw-form-input mb-3"
                                              rows="3"
                                              maxlength="1000"
                                              placeholder="Enter a product description..."
                                              x-init="$el.focus()">{{ product.description|default:'' }}</textarea>
                                    <div class="flex gap-2">
                                        <button type="submit" class="tw-btn-primary text-sm">
                                            <i class="fas fa-check mr-1"></i>Save
                                        </button>
                                        <button type="button"
                                                class="tw-btn-secondary text-sm"
                                                @click="editing = false">Cancel</button>
                                    </div>
                                </form>
                            </template>
                        </div>
                    {% elif product.description %}
                        <p class="text-text-muted text-sm m-0 mt-1">{{ product.description }}</p>
                    {% endif %}
                </div>
            </div>
            {# Visibility toggle + meatball menu #}
            {% if product.has_crud_permissions %}
                <div class="flex-shrink-0 flex items-center gap-2"
                     x-data="{ pmenu: false, isPublic: {{ product.is_public|yesno:'true,false' }} }"
                     @public-status-changed.window="if ($event.detail.itemType === 'product' && $event.detail.itemId === '{{ product.id }}') isPublic = $event.detail.isPublic"
                     @keydown.escape.window="pmenu = false">
                    {% url 'core:product_details_public' product.id as product_public_url %}
                    {% include 'core/components/product_visibility_selector.html.j2' with item_id=product.id is_public=product.is_public %}
                    <div class="relative">
                        <button type="button"
                                class="w-10 h-10 rounded-lg border border-border bg-surface text-text-muted hover:border-primary/40 hover:text-primary transition-colors flex items-center justify-center"
                                @click="pmenu = !pmenu"
                                :aria-expanded="pmenu"
                                aria-haspopup="true"
                                aria-label="More actions">
                            <i class="fas fa-ellipsis-vertical" aria-hidden="true"></i>
                        </button>
                        <div x-show="pmenu"
                             x-cloak
                             x-transition
                             @click.outside="pmenu = false"
                             class="absolute right-0 top-12 w-64 bg-surface border border-border rounded-xl shadow-lg p-1.5 z-40"
                             role="menu">
                            <div class="px-2.5 pt-1.5 pb-1 text-[10px] font-bold tracking-wider text-text-muted uppercase">Product</div>
                            <a href="{% url 'core:sbom_download_product' product.id %}"
                               role="menuitem"
                               class="flex items-center gap-3 w-full px-2.5 py-2 rounded-lg text-sm font-semibold text-text hover:bg-background text-left no-underline">
                                <i class="fas fa-download w-4 text-text-muted" aria-hidden="true"></i>Download SBOM · CycloneDX
                            </a>
                            <a href="{% url 'core:sbom_download_product' product.id %}?format=spdx"
                               role="menuitem"
                               class="flex items-center gap-3 w-full px-2.5 py-2 rounded-lg text-sm font-semibold text-text hover:bg-background text-left no-underline">
                                <i class="fas fa-download w-4 text-text-muted" aria-hidden="true"></i>Download SBOM · SPDX
                            </a>
                            {# Sharing actions appear the moment the product goes public, no reload. #}
                            <template x-if="isPublic">
                                <div>
                                    <hr class="my-1.5 border-border">
                                    <div class="px-2.5 pt-1 pb-1 text-[10px] font-bold tracking-wider text-text-muted uppercase">Sharing</div>
                                    <button type="button"
                                            role="menuitem"
                                            class="flex items-center gap-3 w-full px-2.5 py-2 rounded-lg text-sm font-semibold text-text hover:bg-background text-left"
                                            @click="pmenu = false; navigator.clipboard.writeText('{{ APP_BASE_URL }}{{ product_public_url }}').then(() => $dispatch('messages', { value: [{ type: 'success', message: 'Public URL copied to clipboard' }] }))">
                                        <i class="fas fa-link w-4 text-text-muted" aria-hidden="true"></i>Copy public URL
                                    </button>
                                    <button type="button"
                                            role="menuitem"
                                            class="flex items-center gap-3 w-full px-2.5 py-2 rounded-lg text-sm font-semibold text-text hover:bg-background text-left"
                                            @click="pmenu = false; navigator.clipboard.writeText('[![sbomified](https://sbomify.com/assets/images/logo/badge.svg)]({{ APP_BASE_URL }}{{ product_public_url }})').then(() => $dispatch('messages', { value: [{ type: 'success', message: 'Badge markdown copied to clipboard' }] }))">
                                        <i class="fas fa-certificate w-4 text-text-muted" aria-hidden="true"></i>Copy badge
                                    </button>
                                </div>
                            </template>
                            <hr class="my-1.5 border-border">
                            <div class="px-2.5 pt-1 pb-1 text-[10px] font-bold tracking-wider text-text-muted uppercase">Releases</div>
                            <a href="{% url 'core:product_releases' product.id %}"
                               role="menuitem"
                               class="flex items-center gap-3 w-full px-2.5 py-2 rounded-lg text-sm font-semibold text-text hover:bg-background text-left no-underline">
                                <i class="fas fa-plus w-4 text-text-muted" aria-hidden="true"></i>Create release…
                            </a>
                        </div>
                    </div>
                </div>
            {% endif %}
        </div>
        {# Stats chips + severity rollup #}
        <div class="flex flex-wrap gap-2 items-center">
            <div class="flex items-center gap-1.5 px-3 py-1.5 bg-surface border border-border rounded-md text-sm">
                <i class="fas fa-puzzle-piece text-primary text-xs"></i>
                <span class="font-semibold text-text">{{ component_rows|length }}</span>
                <span class="text-text-muted">Components</span>
            </div>
            <div class="flex items-center gap-1.5 px-3 py-1.5 bg-surface border border-border rounded-md text-sm">
                <i class="fas fa-tag text-primary text-xs"></i>
                <span class="font-semibold text-text">{{ releases_summary.total }}</span>
                <span class="text-text-muted">Releases</span>
            </div>
            {% if vuln_rollup.critical or vuln_rollup.high or vuln_rollup.medium or vuln_rollup.low %}
                <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-md text-sm {% if vuln_rollup.critical or vuln_rollup.high %}bg-danger/10 border border-danger/20{% else %}bg-warning/10 border border-warning/20{% endif %}">
                    <i class="fas fa-triangle-exclamation text-xs {% if vuln_rollup.critical or vuln_rollup.high %}text-danger{% else %}text-warning{% endif %}"></i>
                    {% if vuln_rollup.critical %}
                        <span class="font-semibold text-danger">{{ vuln_rollup.critical }} Critical</span>
                    {% endif %}
                    {% if vuln_rollup.high %}
                        {% if vuln_rollup.critical %}<span class="text-text-muted">·</span>{% endif %}
                        <span class="font-semibold text-severity-high">{{ vuln_rollup.high }} High</span>
                    {% endif %}
                    {% if vuln_rollup.medium %}
                        {% if vuln_rollup.critical or vuln_rollup.high %}<span class="text-text-muted">·</span>{% endif %}
                        <span class="font-semibold text-info">{{ vuln_rollup.medium }} Medium</span>
                    {% endif %}
                    {% if vuln_rollup.low %}
                        {% if vuln_rollup.critical or vuln_rollup.high or vuln_rollup.medium %}
                            <span class="text-text-muted">·</span>
                        {% endif %}
                        <span class="font-semibold text-text-muted">{{ vuln_rollup.low }} Low</span>
                    {% endif %}
                    <span class="text-text-muted">· across {{ component_rows|length }} component{{ component_rows|length|pluralize }}</span>
                </div>
            {% endif %}
        </div>
        {# Components & security #}
        {{ component_terms|json_script:"pc-terms" }}
        {{ component_statuses|json_script:"pc-statuses" }}
        {{ assigned_component_ids|json_script:"pc-assigned" }}
        <section class="tw-card"
                 x-data="{ search: '', status: 'all', currentPage: 1, perPage: 5, terms: (window.parseJsonScript('pc-terms') || []), statuses: (window.parseJsonScript('pc-statuses') || []), get statusOptions() { const order = ['critical', 'high', 'medium', 'low', 'clean', 'not_scanned']; const present = new Set(this.statuses); return order.filter(v => present.has(v)); }, get filteredIdx() { const q = this.search.trim().toLowerCase(); return this.terms.map((t, i) => i).filter(i => (!q || this.terms[i].includes(q)) && (this.status === 'all' || this.statuses[i] === this.status)); }, get total() { return this.filteredIdx.length; }, get totalPages() { return Math.max(1, Math.ceil(this.total / this.perPage)); }, get pageSet() { return new Set(this.filteredIdx.slice((this.currentPage - 1) * this.perPage, this.currentPage * this.perPage)); }, get startIdx() { return this.total ? (this.currentPage - 1) * this.perPage + 1 : 0; }, get endIdx() { return Math.min(this.currentPage * this.perPage, this.total); }, assignOpen: false, availLoading: false, avail: [], selectedId: '', busy: false, err: '', assignedIds: (window.parseJsonScript('pc-assigned') || []), openAssign() { this.assignOpen = true; this.err = ''; this.selectedId = ''; this.availLoading = true; fetch('/api/v1/components').then(r => r.json()).then(d => { const items = d.items || d; this.avail = items.filter(c => !this.assignedIds.includes(c.id)).sort((a, b) => a.name.localeCompare(b.name)); }).catch(() => { this.err = 'Failed to load components'; }).finally(() => { this.availLoading = false; }); }, patchIds(ids) { this.busy = true; return fetch('/api/v1/products/{{ product.id }}', { method: 'PATCH', headers: { 'Content-Type': 'application/json', 'X-CSRFToken': (document.cookie.match(/csrftoken=([^;]+)/) || [])[1] || '' }, body: JSON.stringify({ component_ids: ids }) }).then(r => { if (!r.ok) throw new Error(); location.reload(); }).catch(() => { this.busy = false; this.err = 'Update failed'; }); }, confirmAssign() { if (this.selectedId && !this.busy) this.patchIds([...this.assignedIds, this.selectedId]); }, removeTarget: null, confirmRemove() { if (this.removeTarget && !this.busy) this.patchIds(this.assignedIds.filter(x => x !== this.removeTarget.id)); } }"
                 x-init="$watch('search', () => currentPage = 1); $watch('status', () => currentPage = 1)">
            <div class="px-6 py-4 border-b border-border flex items-center justify-between gap-3 flex-wrap">
                <h4 class="text-lg font-semibold text-text m-0">Components</h4>
                {% if product.has_crud_permissions and component_rows %}
                    <button type="button" class="tw-btn-primary text-sm" @click="openAssign()">
                        <i class="fas fa-plus mr-1"></i>Assign component
                    </button>
                {% endif %}
            </div>
            {% if component_rows %}
                <div class="px-6 py-4 border-b border-border flex flex-wrap items-center gap-3">
                    <div class="tw-data-table-search max-w-xs">
                        <i class="fas fa-search tw-data-table-search-icon"></i>
                        <label for="pc-search" class="sr-only">Search components</label>
                        <input type="search"
                               id="pc-search"
                               x-model="search"
                               placeholder="Search components..."
                               class="tw-data-table-search-input" />
                    </div>
                    <label for="pc-status" class="sr-only">Filter by status</label>
                    <select id="pc-status"
                            x-model="status"
                            class="tw-data-table-page-size-select">
                        <option value="all">All Statuses</option>
                        <template x-for="v in statusOptions" :key="v">
                            <option :value="v"
                                    x-text="v === 'not_scanned' ? 'Not scanned' : v.charAt(0).toUpperCase() + v.slice(1)">
                            </option>
                        </template>
                    </select>
                </div>
                <div class="overflow-x-auto" x-cloak>
                    <table class="tw-table w-full">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Latest version</th>
                                <th>Vulnerabilities</th>
                                <th>Last scan</th>
                                {% if product.has_crud_permissions %}<th class="text-center">Actions</th>{% endif %}
                            </tr>
                        </thead>
                        <tbody>
                            {% for row in component_rows %}
                                <tr x-show="pageSet.has({{ forloop.counter0 }})">
                                    <td>
                                        <a href="{% url 'core:component_details' row.id %}"
                                           class="text-primary font-medium hover:underline">{{ row.name }}</a>
                                    </td>
                                    <td>
                                        {% if row.version %}
                                            <span class="font-mono text-sm text-text" title="{{ row.version }}">{{ row.version|truncatechars:24 }}</span>
                                        {% else %}
                                            <span class="text-text-muted">—</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if row.vuln is None %}
                                            <span class="text-text-muted text-sm">Not scanned</span>
                                        {% elif row.vuln.total == 0 %}
                                            <span class="tw-badge-success text-xs">Clean</span>
                                        {% else %}
                                            <div class="flex items-center gap-1.5 flex-wrap">
                                                {% if row.vuln.critical %}
                                                    <span class="px-2 py-0.5 rounded text-xs font-bold bg-danger/10 text-danger">{{ row.vuln.critical }} Critical</span>
                                                {% endif %}
                                                {% if row.vuln.high %}
                                                    <span class="px-2 py-0.5 rounded text-xs font-bold bg-severity-high-soft text-severity-high">{{ row.vuln.high }} High</span>
                                                {% endif %}
                                                {% if row.vuln.medium %}
                                                    <span class="px-2 py-0.5 rounded text-xs font-bold bg-info/10 text-info">{{ row.vuln.medium }} Medium</span>
                                                {% endif %}
                                                {% if row.vuln.low %}
                                                    <span class="px-2 py-0.5 rounded text-xs font-bold bg-surface text-text-muted border border-border">{{ row.vuln.low }} Low</span>
                                                {% endif %}
                                            </div>
                                        {% endif %}
                                    </td>
                                    <td class="text-sm text-text-muted whitespace-nowrap">
                                        {% if row.last_scan %}
                                            {{ row.last_scan|naturaltime }}
                                        {% else %}
                                            —
                                        {% endif %}
                                    </td>
                                    {% if product.has_crud_permissions %}
                                        <td class="text-center">
                                            <button type="button"
                                                    class="p-2 rounded-lg text-text-muted hover:text-danger hover:bg-danger/10 transition-colors"
                                                    title="Remove from product"
                                                    aria-label="Remove {{ row.name }} from product"
                                                    :disabled="busy"
                                                    @click="removeTarget = { id: '{{ row.id }}', name: '{{ row.name|escapejs }}' }">
                                                <i class="fas fa-unlink" aria-hidden="true"></i>
                                            </button>
                                        </td>
                                    {% endif %}
                                </tr>
                            {% endfor %}
                            <tr x-show="total === 0">
                                <td colspan="{% if product.has_crud_permissions %}5{% else %}4{% endif %}"
                                    class="text-center py-8 text-text-muted">No components match your search.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div class="px-6 py-3 border-t border-border flex flex-wrap items-center justify-between gap-3">
                    <span class="text-sm text-text-muted">
                        Showing <span x-text="startIdx"></span> to <span x-text="endIdx"></span> of <span x-text="total"></span>
                    </span>
                    {% include "components/tw/table_pager.html.j2" %}
                </div>
            {% else %}
                {% include "components/tw/empty_state.html.j2" with icon="fas fa-puzzle-piece" title="No components assigned yet" message="Components are shared building blocks — assign an existing one, or create a component and connect CI/CD so your first push reports here." action_text="Assign a component" action_click="openAssign()" secondary_text="or create a new one" secondary_url="/components/" %}
            {% endif %}
            {# Assign modal #}
            {% if product.has_crud_permissions %}
                <div x-show="assignOpen"
                     x-cloak
                     class="fixed inset-0 z-50 flex items-center justify-center p-4"
                     role="dialog"
                     aria-modal="true"
                     aria-label="Assign component">
                    <div class="absolute inset-0 bg-black/50" @click="assignOpen = false"></div>
                    <div class="relative bg-surface border border-border rounded-xl shadow-xl w-full max-w-md p-6"
                         @keydown.escape.window="assignOpen = false">
                        <h4 class="text-lg font-semibold text-text m-0 mb-1">Assign component</h4>
                        <p class="text-sm text-text-muted mt-0 mb-4">Components are shared — one component can live in several products.</p>
                        <div x-show="availLoading" class="py-6 text-center text-text-muted">
                            <i class="fas fa-spinner fa-spin mr-2"></i>Loading components…
                        </div>
                        <template x-if="!availLoading && avail.length === 0 && !err">
                            <p class="text-sm text-text-muted">Every component in this workspace is already assigned.</p>
                        </template>
                        <template x-if="!availLoading && avail.length > 0">
                            <div>
                                <label for="pc-assign-select" class="sr-only">Component</label>
                                <select id="pc-assign-select"
                                        x-model="selectedId"
                                        class="tw-form-input w-full">
                                    <option value="">Choose a component…</option>
                                    <template x-for="c in avail" :key="c.id">
                                        <option :value="c.id" x-text="c.name"></option>
                                    </template>
                                </select>
                            </div>
                        </template>
                        <p x-show="err" class="text-sm text-danger mt-3" x-text="err"></p>
                        <div class="flex justify-end gap-2 mt-5">
                            <button type="button"
                                    class="tw-btn-secondary text-sm"
                                    @click="assignOpen = false">Cancel</button>
                            <button type="button"
                                    class="tw-btn-primary text-sm"
                                    :disabled="!selectedId || busy"
                                    @click="confirmAssign()">
                                <span x-show="!busy">Assign</span>
                                <span x-show="busy"><i class="fas fa-spinner fa-spin mr-1"></i>Assigning…</span>
                            </button>
                        </div>
                    </div>
                </div>
                {# Remove confirmation #}
                <div x-show="removeTarget !== null"
                     x-cloak
                     class="fixed inset-0 z-50 flex items-center justify-center p-4"
                     role="dialog"
                     aria-modal="true"
                     aria-label="Remove component from product">
                    <div class="absolute inset-0 bg-black/50" @click="removeTarget = null"></div>
                    <div class="relative bg-surface border border-border rounded-xl shadow-xl w-full max-w-md p-6"
                         @keydown.escape.window="removeTarget = null">
                        <h4 class="text-lg font-semibold text-text m-0 mb-1">
                            Remove <span x-text="removeTarget?.name"></span>?
                        </h4>
                        <p class="text-sm text-text-muted mt-0 mb-4">
                            The component is only unassigned from this product — it stays in your workspace and in any other products that use it.
                        </p>
                        <p x-show="err" class="text-sm text-danger mb-3" x-text="err"></p>
                        <div class="flex justify-end gap-2">
                            <button type="button"
                                    class="tw-btn-secondary text-sm"
                                    @click="removeTarget = null">Cancel</button>
                            <button type="button"
                                    class="tw-btn-danger text-sm"
                                    :disabled="busy"
                                    @click="confirmRemove()">
                                <span x-show="!busy">Remove</span>
                                <span x-show="busy"><i class="fas fa-spinner fa-spin mr-1"></i>Removing…</span>
                            </button>
                        </div>
                    </div>
                </div>
            {% endif %}
        </section>
        {# Releases strip #}
        <section class="tw-card">
            <div class="px-6 py-4 {% if releases_summary.latest %}border-b border-border{% endif %} flex items-center justify-between gap-3">
                <h4 class="text-lg font-semibold text-text m-0">Releases</h4>
                <span class="text-xs text-text-muted">Snapshots of this product's artifacts</span>
            </div>
            {% if releases_summary.latest %}
                <div class="px-6 py-3.5 flex items-center gap-3 flex-wrap text-sm text-text-muted">
                    <a href="{% url 'core:release_details' product.id releases_summary.latest.id %}"
                       class="font-semibold text-text hover:text-primary no-underline">{{ releases_summary.latest.name }}</a>
                    {% if releases_summary.latest.is_latest %}
                        <span class="text-[10px] font-extrabold tracking-wider uppercase text-success bg-success/10 rounded px-2 py-0.5">Latest</span>
                    {% endif %}
                    {% if releases_summary.latest.is_prerelease %}
                        <span class="text-[10px] font-extrabold tracking-wider uppercase text-warning bg-warning/10 rounded px-2 py-0.5">Pre-release</span>
                    {% endif %}
                    <span>{{ releases_summary.latest.artifact_count }} artifact{{ releases_summary.latest.artifact_count|pluralize }}</span>
                    <span>{{ releases_summary.latest.date|date:"M d, Y" }}</span>
                    <a href="{% url 'core:product_releases' product.id %}"
                       class="ml-auto text-sm font-semibold text-primary no-underline hover:underline">View all {{ releases_summary.total }} release{{ releases_summary.total|pluralize }} <i class="fas fa-arrow-right text-xs" aria-hidden="true"></i></a>
                </div>
            {% else %}
                {% url 'core:product_releases' product.id as releases_url %}
                {% include "components/tw/empty_state.html.j2" with compact=True icon="fas fa-tag" title="No releases yet" message="A release freezes this product's artifacts at a point in time — tag one when you ship." action_text="Create a release" action_url=releases_url action_variant="secondary" %}
            {% endif %}
        </section>
        {# About this product — compliance & metadata, uniform collapsed rows #}
        <section class="tw-card">
            <div class="px-6 py-4 border-b border-border flex items-center justify-between gap-3">
                <h4 class="text-lg font-semibold text-text m-0">About this product</h4>
                <span class="text-xs text-text-muted">Compliance &amp; metadata</span>
            </div>
            {% if has_cra_access %}
                <div x-data="{ open: false }" class="border-b border-border">
                    <button type="button"
                            class="w-full flex items-center gap-3 px-6 py-3.5 text-left hover:bg-background/50 transition-colors"
                            :aria-expanded="open"
                            @click="open = !open">
                        <span class="w-8 h-8 rounded-lg bg-text-muted/10 flex items-center justify-center text-text-muted"><i class="fas fa-shield-halved text-sm"></i></span>
                        <span>
                            <span class="block text-sm font-semibold text-text">CRA Compliance</span>
                            <span class="block text-xs text-text-muted">
                                {% if cra_assessment %}
                                    In progress · step {{ cra_assessment.current_step }}
                                {% else %}
                                    Not started
                                {% endif %}
                            </span>
                        </span>
                        <i class="fas fa-chevron-down ml-auto text-text-muted transition-transform"
                           :class="open ? 'rotate-180' : ''"
                           aria-hidden="true"></i>
                    </button>
                    <div x-show="open" x-collapse>
                        <div class="tw-embed">{% include "compliance/components/cra_product_card.html.j2" %}</div>
                    </div>
                </div>
            {% endif %}
            <div x-data="{ open: false }" class="border-b border-border">
                <button type="button"
                        class="w-full flex items-center gap-3 px-6 py-3.5 text-left hover:bg-background/50 transition-colors"
                        :aria-expanded="open"
                        @click="open = !open">
                    <span class="w-8 h-8 rounded-lg bg-text-muted/10 flex items-center justify-center text-text-muted"><i class="fas fa-link text-sm"></i></span>
                    <span>
                        <span class="block text-sm font-semibold text-text">Product links</span>
                        <span class="block text-xs text-text-muted">Website, docs, support…</span>
                    </span>
                    <i class="fas fa-chevron-down ml-auto text-text-muted transition-transform"
                       :class="open ? 'rotate-180' : ''"
                       aria-hidden="true"></i>
                </button>
                <div x-show="open" x-collapse>
                    <div class="tw-embed"
                         hx-get="{% url 'core:product_links' product.id %}"
                         hx-trigger="click once from:previous button"
                         hx-swap="innerHTML">
                        <div class="px-6 pb-4 text-sm text-text-muted">Loading…</div>
                    </div>
                </div>
            </div>
            <div x-data="{ open: false }" class="border-b border-border">
                <button type="button"
                        class="w-full flex items-center gap-3 px-6 py-3.5 text-left hover:bg-background/50 transition-colors"
                        :aria-expanded="open"
                        @click="open = !open">
                    <span class="w-8 h-8 rounded-lg bg-text-muted/10 flex items-center justify-center text-text-muted"><i class="fas fa-barcode text-sm"></i></span>
                    <span>
                        <span class="block text-sm font-semibold text-text">Product identifiers</span>
                        <span class="block text-xs text-text-muted">GTIN, SKU, MPN…</span>
                    </span>
                    {% if identifiers_locked %}
                        <span class="ml-auto mr-3 text-[10px] font-bold tracking-wider uppercase text-warning bg-warning/10 rounded px-2 py-0.5"><i class="fas fa-lock mr-1"></i>Business</span>
                        <i class="fas fa-chevron-down text-text-muted transition-transform"
                           :class="open ? 'rotate-180' : ''"
                           aria-hidden="true"></i>
                    {% else %}
                        <i class="fas fa-chevron-down ml-auto text-text-muted transition-transform"
                           :class="open ? 'rotate-180' : ''"
                           aria-hidden="true"></i>
                    {% endif %}
                </button>
                <div x-show="open" x-collapse>
                    <div class="tw-embed"
                         hx-get="{% url 'core:product_identifiers' product.id %}"
                         hx-trigger="click once from:previous button"
                         hx-swap="innerHTML">
                        <div class="px-6 pb-4 text-sm text-text-muted">Loading…</div>
                    </div>
                </div>
            </div>
            <div x-data="{ open: false }">
                <button type="button"
                        class="w-full flex items-center gap-3 px-6 py-3.5 text-left hover:bg-background/50 transition-colors"
                        :aria-expanded="open"
                        @click="open = !open">
                    <span class="w-8 h-8 rounded-lg bg-text-muted/10 flex items-center justify-center text-text-muted"><i class="fas fa-clock text-sm"></i></span>
                    <span>
                        <span class="block text-sm font-semibold text-text">Lifecycle</span>
                        <span class="block text-xs text-text-muted">Release, end of support, end of life</span>
                    </span>
                    <i class="fas fa-chevron-down ml-auto text-text-muted transition-transform"
                       :class="open ? 'rotate-180' : ''"
                       aria-hidden="true"></i>
                </button>
                <div x-show="open" x-collapse>
                    <div class="tw-embed"
                         hx-get="{% url 'core:product_lifecycle' product.id %}"
                         hx-trigger="click once from:previous button"
                         hx-swap="innerHTML">
                        <div class="px-6 pb-4 text-sm text-text-muted">Loading…</div>
                    </div>
                </div>
            </div>
        </section>
        {# Danger Zone #}
        {% if product.has_crud_permissions %}
            <div>{% include 'components/product_danger_zone.html.j2' with product_id=product.id product_name=product.name %}</div>
        {% endif %}
    </div>
{% endblock %}
{% block scripts %}
    {% vite_asset 'sbomify/apps/core/js/main.ts' %}
    {% vite_asset 'sbomify/apps/sboms/js/main.ts' %}
{% endblock %}
