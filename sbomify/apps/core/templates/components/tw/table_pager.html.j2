{# Compact table pager — expects `currentPage`, `totalPages` in the Alpine scope. #}
<div class="flex items-center gap-2" x-show="totalPages > 1">
    <button type="button"
            class="tw-btn-secondary text-sm px-3 py-1 disabled:opacity-50 disabled:cursor-not-allowed"
            :disabled="currentPage === 1"
            @click="if (currentPage > 1) currentPage--"
            aria-label="Previous page">
        <i class="fas fa-chevron-left text-xs" aria-hidden="true"></i>
    </button>
    <span class="text-sm text-text-muted">Page <span x-text="currentPage"></span> / <span x-text="totalPages"></span></span>
    <button type="button"
            class="tw-btn-secondary text-sm px-3 py-1 disabled:opacity-50 disabled:cursor-not-allowed"
            :disabled="currentPage === totalPages"
            @click="if (currentPage < totalPages) currentPage++"
            aria-label="Next page">
        <i class="fas fa-chevron-right text-xs" aria-hidden="true"></i>
    </button>
</div>
