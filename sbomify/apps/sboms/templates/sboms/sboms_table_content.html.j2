{% load static %}
{% load json_extras %}
{% load humanize %}
{% if not sboms %}
    <div class="flex flex-col items-center justify-center py-12 px-6">
        <div class="w-16 h-16 rounded-full bg-border/30 flex items-center justify-center mb-4">
            <i class="fas fa-file-code text-2xl text-text-muted"></i>
        </div>
        <p class="text-text-muted text-center">No BOMs found for this component.</p>
    </div>
{% else %}
    <div class="tw-data-table">
        <div class="tw-data-table-toolbar">
            <div class="tw-data-table-toolbar-left">
                <div class="tw-data-table-search">
                    <i class="fas fa-search tw-data-table-search-icon"></i>
                    <label for="sboms-search" class="sr-only">Search artifacts</label>
                    <input type="search"
                           id="sboms-search"
                           x-model="search"
                           @input="currentPage = 1"
                           placeholder="Search artifacts..."
                           class="tw-data-table-search-input">
                </div>
                <label for="sboms-type-filter" class="sr-only">Filter by type</label>
                <select id="sboms-type-filter"
                        x-model="typeFilter"
                        @change="currentPage = 1"
                        class="tw-data-table-page-size-select">
                    <option value="all">All Types</option>
                    <option value="sbom">SBOM</option>
                    <option value="vex">VEX</option>
                    <option value="cbom">CBOM</option>
                </select>
            </div>
            {% if full_view %}
                <div class="tw-data-table-toolbar-right">
                    <div class="tw-data-table-page-size">
                        <span>Show</span>
                        <label for="sboms-per-page" class="sr-only">Entries per page</label>
                        <select id="sboms-per-page"
                                x-model.number="pageSize"
                                @change="currentPage = 1"
                                class="tw-data-table-page-size-select">
                            <template x-for="size in pageSizeOptions" :key="size">
                                <option :value="size" x-text="size"></option>
                            </template>
                        </select>
                        <span>entries</span>
                    </div>
                </div>
            {% endif %}
        </div>
        <div class="tw-data-table-container">
            <table class="tw-table w-full">
                <thead>
                    <tr>
                        <th :aria-sort="sortColumn === 'name' ? (sortDirection === 'asc' ? 'ascending' : 'descending') : 'none'">
                            <button type="button"
                                    class="tw-table-sortable"
                                    :class="{ 'sorted-asc': sortColumn === 'name' && sortDirection === 'asc', 'sorted-desc': sortColumn === 'name' && sortDirection === 'desc' }"
                                    @click="sort('name')">
                                Name
                                <span class="tw-table-sort-icon" aria-hidden="true">
                                    <i class="fas fa-caret-up"></i>
                                    <i class="fas fa-caret-down"></i>
                                </span>
                            </button>
                        </th>
                        <th>Type</th>
                        <th class="hidden md:table-cell"
                            :aria-sort="sortColumn === 'version' ? (sortDirection === 'asc' ? 'ascending' : 'descending') : 'none'">
                            <button type="button"
                                    class="tw-table-sortable"
                                    :class="{ 'sorted-asc': sortColumn === 'version' && sortDirection === 'asc', 'sorted-desc': sortColumn === 'version' && sortDirection === 'desc' }"
                                    @click="sort('version')">
                                Version
                                <span class="tw-table-sort-icon" aria-hidden="true">
                                    <i class="fas fa-caret-up"></i>
                                    <i class="fas fa-caret-down"></i>
                                </span>
                            </button>
                        </th>
                        {% if not is_public_view %}<th>Vulnerabilities</th>{% endif %}
                        {% if not is_public_view %}<th class="hidden lg:table-cell">Assessments</th>{% endif %}
                        <th :aria-sort="sortColumn === 'created_at' ? (sortDirection === 'asc' ? 'ascending' : 'descending') : 'none'">
                            <button type="button"
                                    class="tw-table-sortable"
                                    :class="{ 'sorted-asc': sortColumn === 'created_at' && sortDirection === 'asc', 'sorted-desc': sortColumn === 'created_at' && sortDirection === 'desc' }"
                                    @click="sort('created_at')">
                                Uploaded
                                <span class="tw-table-sort-icon" aria-hidden="true">
                                    <i class="fas fa-caret-up"></i>
                                    <i class="fas fa-caret-down"></i>
                                </span>
                            </button>
                        </th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <template x-for="item in paginatedData" :key="item.sbom.id">
                        <tr class="hover:bg-background/50 transition-colors"
                            x-data="{ get bomType() { return item.sbom.bom_type || 'sbom' } }">
                            <td class="break-all">
                                <a :href="'{% if is_public_view %}{% url 'core:component_item_public' component_id=component_id item_type='sboms' item_id='SBOM_ID' %}{% else %}{% url 'core:component_item' component_id=component_id item_type='sboms' item_id='SBOM_ID' %}{% endif %}'.replace('SBOM_ID', item.sbom.id)"
                                   class="text-primary font-medium hover:underline"
                                   x-text="item.sbom.name"></a>
                                {% comment %}
                                Mobile fallback for the columns hidden under md: format pill (with format_version)
                                plus the SBOM version. flex-wrap lets each pill drop to its own line if the column
                                is narrow, so the table doesn't horizontally scroll.
                                {% endcomment %}
                                <div class="md:hidden mt-1 flex flex-wrap items-center gap-1.5 text-xs">
                                    <span class="tw-sbom-format"
                                          :class="item.sbom.format.toLowerCase().includes('cyclonedx') ? 'tw-sbom-format-cyclonedx' : 'tw-sbom-format-spdx'"
                                          x-text="(item.sbom.format_display || item.sbom.format).toUpperCase() + ' ' + item.sbom.format_version"></span>
                                    <span class="text-text-muted font-mono"
                                          x-text="'v' + (item.sbom.version.length > 16 ? item.sbom.version.slice(0, 16) + '…' : item.sbom.version)"
                                          :title="item.sbom.version"></span>
                                </div>
                            </td>
                            <td>
                                <span class="tw-badge text-xs"
                                      :class="{ 'tw-badge-info': bomType === 'sbom', 'tw-badge-warning': bomType === 'vex', 'tw-badge-success': bomType === 'cbom', 'tw-badge-secondary': !['sbom','vex','cbom'].includes(bomType) }"
                                      x-text="bomType.toUpperCase()"></span>
                            </td>
                            <td class="hidden md:table-cell">
                                <span class="font-mono text-sm text-text"
                                      x-text="item.sbom.version.length > 20 ? item.sbom.version.slice(0, 20) + '...' : item.sbom.version"
                                      :title="item.sbom.version"></span>
                            </td>
                            {% if not is_public_view %}
                                <td class="whitespace-nowrap">
                                    <template x-if="!item.vuln">
                                        <span class="text-text-muted text-sm">Not scanned</span>
                                    </template>
                                    <template x-if="item.vuln && item.vuln.total === 0">
                                        <span class="tw-badge-success text-xs">Clean</span>
                                    </template>
                                    <template x-if="item.vuln && item.vuln.total > 0">
                                        <div class="flex items-center gap-1.5 flex-wrap">
                                            <template x-if="item.vuln.critical > 0">
                                                <span class="px-2 py-0.5 rounded text-xs font-bold bg-danger/10 text-danger"
                                                      x-text="item.vuln.critical + ' Critical'"></span>
                                            </template>
                                            <template x-if="item.vuln.high > 0">
                                                <span class="px-2 py-0.5 rounded text-xs font-bold bg-warning/10 text-warning"
                                                      x-text="item.vuln.high + ' High'"></span>
                                            </template>
                                            <template x-if="item.vuln.medium > 0">
                                                <span class="px-2 py-0.5 rounded text-xs font-bold bg-info/10 text-info"
                                                      x-text="item.vuln.medium + ' Medium'"></span>
                                            </template>
                                            <template x-if="item.vuln.low > 0">
                                                <span class="px-2 py-0.5 rounded text-xs font-bold bg-surface text-text-muted border border-border"
                                                      x-text="item.vuln.low + ' Low'"></span>
                                            </template>
                                        </div>
                                    </template>
                                </td>
                                <td class="hidden lg:table-cell">
                                    <template x-if="bomType === 'sbom' && item.assessments && item.assessments.plugins && item.assessments.plugins.length > 0">
                                        <div class="flex flex-wrap items-center gap-1">
                                            <!-- Individual plugin badges (show up to 3) -->
                                            <template x-for="plugin in item.assessments.plugins.slice(0, 3)"
                                                      :key="plugin.name">
                                                <span class="tw-assessment-pill"
                                                      :class="{ 'tw-assessment-pass': plugin.status === 'pass', 'tw-assessment-fail': plugin.status === 'fail', 'tw-assessment-pending': plugin.status === 'pending', 'tw-assessment-error': plugin.status === 'error' }"
                                                      :title="plugin.display_name + ' - ' + (plugin.status === 'pass' ? 'Passed' : plugin.status === 'fail' ? 'Failed (' + plugin.fail_count + ')' : plugin.status.charAt(0).toUpperCase() + plugin.status.slice(1))">
                                                    <i :class="{ 'fas fa-check': plugin.status === 'pass', 'fas fa-xmark': plugin.status === 'fail', 'fas fa-clock': plugin.status === 'pending', 'fas fa-triangle-exclamation': plugin.status === 'error' }"></i>
                                                    <span class="tw-assessment-pill-text"
                                                          x-text="plugin.display_name.length > 8 ? plugin.display_name.slice(0, 8) + '...' : plugin.display_name"></span>
                                                </span>
                                            </template>
                                            <!-- More indicator with count -->
                                            <template x-if="item.assessments.plugins.length > 3">
                                                <span class="tw-assessment-more"
                                                      :title="(item.assessments.plugins.length - 3) + ' more assessment' + (item.assessments.plugins.length - 3 > 1 ? 's' : '')"
                                                      x-text="'+' + (item.assessments.plugins.length - 3)"></span>
                                            </template>
                                            <!-- Failure summary (only if there are hidden failures) -->
                                            <template x-if="item.assessments.failing_count > 0 && item.assessments.plugins.slice(0, 3).filter(p => p.status === 'fail').length < item.assessments.failing_count">
                                                <span class="tw-assessment-summary-fail"
                                                      :title="item.assessments.failing_count + ' assessment' + (item.assessments.failing_count > 1 ? 's' : '') + ' failed'">
                                                    <i class="fas fa-circle-exclamation"></i>
                                                    <span x-text="item.assessments.failing_count + ' Failed'"></span>
                                                </span>
                                            </template>
                                        </div>
                                    </template>
                                    <template x-if="bomType === 'sbom' && item.assessments && (!item.assessments.plugins || item.assessments.plugins.length === 0) && (item.assessments.overall_status === 'pending' || item.assessments.overall_status === 'in_progress')">
                                        <span class="inline-flex items-center gap-1.5 text-info text-sm">
                                            <i class="fas fa-clock fa-pulse"></i>
                                            <span>Checking...</span>
                                        </span>
                                    </template>
                                    <template x-if="bomType !== 'sbom' || !item.assessments || (item.assessments.overall_status === 'no_assessments' && (!item.assessments.plugins || item.assessments.plugins.length === 0))">
                                        <span class="text-text-muted text-sm">—</span>
                                    </template>
                                </td>
                            {% endif %}
                            <td class="text-text text-sm whitespace-nowrap">
                                <span x-text="new Date(item.sbom.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })"></span>
                                <div class="text-xs text-text-muted"
                                     x-text="(item.sbom.format_display || item.sbom.format).toUpperCase() + ' ' + item.sbom.format_version">
                                </div>
                            </td>
                            <td>
                                <div class="flex items-center justify-center gap-1">
                                    {% comment %}
                                    `from_public=true` flag tells SbomDownloadView to render the friendly
                                    gated-access page instead of a generic 403 when a public visitor hits a
                                    gated SBOM. Internal downloads omit the flag.
                                    {% endcomment %}
                                    <a :href="'{% url 'sboms:sbom_download' 'SBOM_ID' %}'.replace('SBOM_ID', item.sbom.id){% if is_public_view %} + '?from_public=true'{% endif %}"
                                       title="Download"
                                       aria-label="Download SBOM"
                                       class="p-2 rounded-lg text-primary hover:bg-primary/10 transition-colors">
                                        <i class="fas fa-download" aria-hidden="true"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    </template>
                    <template x-if="paginatedData.length === 0 && search">
                        <tr>
                            <td colspan="{% if is_public_view %}5{% else %}7{% endif %}"
                                class="text-center py-8 text-text-muted">
                                <i class="fas fa-search text-2xl mb-2 opacity-50"></i>
                                <p>No BOMs match your search</p>
                                <button @click="search = ''"
                                        class="mt-3 text-xs text-primary hover:underline">Clear search</button>
                            </td>
                        </tr>
                    </template>
                </tbody>
            </table>
        </div>
        <div class="px-6 py-3 border-t border-border flex flex-wrap items-center justify-between gap-3">
            <span class="text-sm text-text-muted">
                Showing <span x-text="startItem"></span> to <span x-text="endItem"></span> of <span x-text="filteredData.length"></span>
                <template x-if="search"><span>(filtered from <span x-text="allSboms.length"></span> total)</span></template>
            </span>
            <div class="flex items-center gap-2" x-show="totalPages > 1">
                <button type="button"
                        class="tw-btn-secondary text-sm px-3 py-1 disabled:opacity-50 disabled:cursor-not-allowed"
                        :disabled="currentPage === 1"
                        @click="goToPage(currentPage - 1)"
                        aria-label="Previous page">
                    <i class="fas fa-chevron-left text-xs" aria-hidden="true"></i>
                </button>
                <span class="text-sm text-text-muted">Page <span x-text="currentPage"></span> / <span x-text="totalPages"></span></span>
                <button type="button"
                        class="tw-btn-secondary text-sm px-3 py-1 disabled:opacity-50 disabled:cursor-not-allowed"
                        :disabled="currentPage === totalPages"
                        @click="goToPage(currentPage + 1)"
                        aria-label="Next page">
                    <i class="fas fa-chevron-right text-xs" aria-hidden="true"></i>
                </button>
            </div>
        </div>
    </div>
{% endif %}
