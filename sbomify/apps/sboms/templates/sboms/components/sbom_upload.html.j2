{# Upload artifact — a modal opened from the component header ⋮ menu (open-upload window event), not a body card. #}
<div x-data="{ uploadOpen: false }"
     @open-upload.window="uploadOpen = true"
     @keydown.escape.window="if (uploadOpen) uploadOpen = false">
    <div x-show="uploadOpen"
         x-cloak
         class="fixed inset-0 z-[100]"
         role="dialog"
         aria-modal="true"
         aria-label="Upload artifact">
        <div x-show="uploadOpen"
             x-transition:enter="transition ease-out duration-200"
             x-transition:enter-start="opacity-0"
             x-transition:enter-end="opacity-100"
             x-transition:leave="transition ease-in duration-150"
             x-transition:leave-start="opacity-100"
             x-transition:leave-end="opacity-0"
             class="tw-modal-overlay"
             @click="uploadOpen = false"></div>
        <div class="tw-modal"
             x-show="uploadOpen"
             x-trap.noscroll="uploadOpen"
             x-transition:enter="transition ease-out duration-200"
             x-transition:enter-start="opacity-0 scale-95"
             x-transition:enter-end="opacity-100 scale-100"
             x-transition:leave="transition ease-in duration-150"
             x-transition:leave-start="opacity-100 scale-100"
             x-transition:leave-end="opacity-0 scale-95"
             @click.stop>
            <div id="upload-sbom"
                 class="tw-modal-content"
                 x-data="sbomUpload('{{ component_id }}', {{ component.sbom_count|default:0 }} > 0)">
                <div class="tw-modal-header">
                    <h4 class="tw-modal-title flex items-center gap-2">
                        <i class="fas fa-upload text-primary"></i>Upload Artifact
                    </h4>
                    <button type="button"
                            class="tw-modal-close"
                            @click="uploadOpen = false"
                            aria-label="Close">
                        <i class="fas fa-times" aria-hidden="true"></i>
                    </button>
                </div>
                <div class="tw-modal-body">
                    <!-- Info Notice -->
                    <div class="flex items-start gap-3 p-4 bg-info/10 rounded-lg mb-4">
                        <i class="fas fa-info-circle text-info mt-0.5"></i>
                        <div class="text-text text-sm">
                            <strong>Recommended:</strong> Use CI/CD Integration for automated uploads. Manual uploads are useful for one-time uploads, testing, or when automated workflows aren't available.
                        </div>
                    </div>
                    <!-- Artifact Type -->
                    <div class="mb-4 flex items-center gap-3">
                        <label for="upload-bom-type" class="text-text text-sm font-medium">Artifact type</label>
                        <select id="upload-bom-type"
                                class="tw-form-select w-auto"
                                x-model="bomType"
                                :disabled="isUploading || isPreviewing || !!preview">
                            <option value="sbom">SBOM</option>
                            <option value="vex">VEX</option>
                        </select>
                    </div>
                    <!-- Upload Area -->
                    <div class="border-2 border-dashed rounded-xl p-8 text-center transition-colors cursor-pointer"
                         :class="{ 'border-primary bg-primary/5': isDragOver, 'border-border hover:border-primary/50': !isDragOver && !isUploading, 'border-border opacity-75': isUploading }"
                         role="button"
                         aria-label="Upload artifact file by dropping or clicking"
                         :aria-busy="isUploading"
                         tabindex="0"
                         @drop.prevent="!isUploading && handleDrop($event)"
                         @dragover.prevent="!isUploading && (isDragOver = true)"
                         @dragleave="!isUploading && (isDragOver = false)"
                         @dragenter.prevent
                         @click="!isUploading && $refs.fileInput && $refs.fileInput.click()"
                         @keydown.enter="!isUploading && $refs.fileInput && $refs.fileInput.click()"
                         @keydown.space.prevent="!isUploading && $refs.fileInput && $refs.fileInput.click()">
                        <!-- Default state -->
                        <template x-if="!isUploading">
                            <div>
                                <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-primary/10 flex items-center justify-center">
                                    <i class="fas fa-cloud-upload-alt text-3xl text-primary"></i>
                                </div>
                                <p class="text-text mb-2">
                                    <strong>Drop your <span x-text="bomTypeLabel"></span> file here</strong> or
                                    <span class="text-primary underline">click to browse</span>
                                </p>
                                <input type="file"
                                       x-ref="fileInput"
                                       :accept="bomType === 'vex' ? '.json,.cdx,.xml' : '.json,.spdx,.cdx'"
                                       class="hidden"
                                       @change="handleFileSelect($event)"
                                       @click.stop>
                                <p class="text-text-muted text-sm m-0">
                                    SBOMs: CycloneDX (.json, .cdx) or SPDX (.json, .spdx). VEX: CycloneDX (JSON or XML), OpenVEX, or CSAF.
                                </p>
                            </div>
                        </template>
                        <!-- Uploading state -->
                        <template x-if="isUploading">
                            <div class="text-center">
                                {% include "components/tw/spinner.html.j2" with size="lg" class="mx-auto mb-4" %}
                                <p class="text-text m-0">
                                    Uploading and processing <span x-text="bomTypeLabel"></span>...
                                </p>
                            </div>
                        </template>
                    </div>
                    <!-- VEX dry-run preview -->
                    <template x-if="isPreviewing">
                        <div class="mt-4 text-center text-text-muted">
                            {% include "components/tw/spinner.html.j2" with size="sm" class="mx-auto mb-2" %}
                            Checking what this VEX would change…
                        </div>
                    </template>
                    <template x-if="preview">
                        <div class="mt-4 border border-border rounded-xl p-4">
                            <h5 class="font-semibold text-text mb-3">
                                <i class="fas fa-flask text-primary mr-1"></i>Preview — nothing stored yet
                            </h5>
                            <div class="grid grid-cols-2 md:grid-cols-4 gap-2 mb-3 text-center">
                                <div class="bg-info/10 p-2 rounded-lg">
                                    <div class="font-bold text-info" x-text="preview.would_suppress"></div>
                                    <small class="text-text-muted">Would suppress</small>
                                </div>
                                <div class="bg-border/30 p-2 rounded-lg">
                                    <div class="font-bold text-text" x-text="preview.already_suppressed"></div>
                                    <small class="text-text-muted">Already suppressed</small>
                                </div>
                                <div class="bg-warning/10 p-2 rounded-lg">
                                    <div class="font-bold text-warning" x-text="preview.unmatched_statements"></div>
                                    <small class="text-text-muted">Statements matching nothing</small>
                                </div>
                                <div class="bg-border/30 p-2 rounded-lg">
                                    <div class="font-bold text-text" x-text="preview.findings_checked"></div>
                                    <small class="text-text-muted">Findings checked</small>
                                </div>
                            </div>
                            <template x-if="preview.matched.length">
                                <ul class="text-sm text-text-muted mb-3 space-y-1">
                                    <template x-for="match in preview.matched.slice(0, 8)"
                                              :key="match.id + (match.package || '')">
                                        <li>
                                            <span class="font-mono" x-text="match.id"></span>
                                            <template x-if="match.package">
                                                <span> — <span x-text="match.package"></span><template x-if="match.version"><span x-text="'@' + match.version"></span></template></span>
                                            </template>
                                            <span class="text-info" x-text="' → ' + match.state"></span>
                                        </li>
                                    </template>
                                </ul>
                            </template>
                            <div class="flex gap-2 justify-end">
                                <button type="button" class="tw-btn-secondary" @click="cancelPreview()">Cancel</button>
                                <button type="button" class="tw-btn-primary" @click="applyPreview()">
                                    <i class="fas fa-upload mr-1"></i>Apply this VEX
                                </button>
                            </div>
                        </div>
                    </template>
                </div>
            </div>
        </div>
    </div>
</div>
